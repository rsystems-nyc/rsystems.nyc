# ── Dev-host access gate (JumpCloud OIDC via Auth.js) ─────────────────────────
# These variables live in .env.local ON THE DEV HOST ONLY (gitignored). They are
# NOT committed and NOT set on Vercel/production — so the gate is completely
# inert in prod. middleware.ts no-ops unless PREVIEW_AUTH_ENABLED is "true", and
# it never gates the production apex regardless.

# Turn the gate on. Only set this to "true" in .env.local on dev.rsystems.nyc.
PREVIEW_AUTH_ENABLED=false

# Auth.js base URL on the dev host (self-hosted behind a proxy → set explicitly).
AUTH_URL=https://dev.rsystems.nyc

# Auth.js session-signing key. Generate with: openssl rand -base64 33
AUTH_SECRET=

# JumpCloud OIDC application (JumpCloud admin → SSO → custom OIDC app).
# Redirect URI to register: https://dev.rsystems.nyc/api/auth/callback/jumpcloud
JUMPCLOUD_ISSUER=https://oauth.id.jumpcloud.com/
JUMPCLOUD_CLIENT_ID=
JUMPCLOUD_CLIENT_SECRET=

# ── Contact "write in" form → HubSpot Forms API ──────────────────────────────
# Public, non-secret values (the Forms submission endpoint needs no API key).
# Set both on Vercel (prod) and in .env.local to make the contact form live;
# until set, the form shows a graceful "email us" fallback. See
# docs/contact-form.md for the one-time HubSpot setup.
HUBSPOT_PORTAL_ID=
HUBSPOT_CONTACT_FORM_GUID=
